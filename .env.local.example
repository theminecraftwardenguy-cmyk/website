# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# MongoDB Atlas connection string
# 1. Sign up at https://cloud.mongodb.com (free M0 cluster)
# 2. Create a database user (Database Access tab)
# 3. Allow network access from 0.0.0.0/0 (Network Access tab)
# 4. Click "Connect" → "Drivers" → copy the connection string
# 5. Replace <password> with your DB user password
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/website-hero?retryWrites=true&w=majority
